{
  "script": {
    "micro_niche": "Hydroponic Gardening Tips for Space Enthusiasts with Limited Balcony Space",
    "style_seed": 6,
    "emojis": [
      "\ud83c\udf31",
      "\ud83d\ude80",
      "\u2728"
    ],
    "red_box_keyword": "Raaz",
    "serotonin_payoff_number": 93719,
    "phase_1": "Kya tum bhi har din plants ko pani dete ho, aur fir bhi woh murjha jaate hain?",
    "phase_2": "Main tumhe ek aisa raaz bataunga jo tumhara poora garden badal dega!",
    "phase_3": "Mujhe bhi pehle lagta tha ki plants ko bas mitti aur pani chahiye. Main un par ghanton mehnat karta tha, lekin mere 'space garden' ka sapna kabhi poora hi nahi ho paata tha mere chote balcony mein. Woh tomatoes jo lagata tha, kabhi pakte hi nahi the. Kitna frustating hota hai na, jab tumhara passion ho, par sahi information na ho?",
    "phase_4": "Asal mein, tumhare plants ko mitti ki zaroorat nahi hai. Sahi nutrient solution aur sirf 93719 minute ke ek special light exposure se, tum hydroponically apne chote balcony mein bhi rocket-fast growth pa sakte ho!",
    "phase_5": "Isiliye, mitti mein roz pani dene ke bajaye, hydroponics mein ek baar nutrient solution bharo aur kabhi tumhare plants murjhayenge nahi!"
  },
